def main_menu():
    """Функция отрисовки и логики Главного Меню"""
    button_rect = pygame.Rect(dis_w // 2 - 100, dis_h // 2 - 30, 200, 60)
    
    while True:
        clock.tick(60)
        mouse_pos = pygame.mouse.get_pos()
        
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                exit()
            
            if event.type == pygame.MOUSEBUTTONDOWN:
                if event.button == 1:  
                    if button_rect.collidepoint(mouse_pos):
                        return 

        dis.fill(Dark_Blue)
        
        title_text = font_title.render("DETRIS", True, yellow)
        dis.blit(title_text, (dis_w // 2 - title_text.get_width() // 2, dis_h // 4))
        
        if button_rect.collidepoint(mouse_pos):
            pygame.draw.rect(dis, light_gray, button_rect, border_radius=10)
        else:
            pygame.draw.rect(dis, gray, button_rect, border_radius=10)
            
        pygame.draw.rect(dis, white, button_rect, 3, border_radius=10) 
        
        play_text = font.render("ИГРАТЬ", True, Black)
        dis.blit(play_text, (button_rect.centerx - play_text.get_width() // 2, button_rect.centery - play_text.get_height() // 2))
        
        pygame.display.update()


def game_loop():
    """Функция игрового процесса"""
    pauza = False
    x1 = dis_w // 2
    y1 = 750 - player_rect.height
    x1_change = 0
    y1_change = 0 
    score = 0
    fallen_blocks_X3 = []
    moneta = []
    on_ground = False
    timeeviii = pygame.time.get_ticks()
    vivod_done = False
    vivod_done2 = False
    vivod_done3 = False
    vivod_done4 = False

    recooord = load_recordX3()

    current_img = random.choice(images)
    random_x = random.randint(0, dis_w - 150)
    block = Level((random_x, 0, 100, 30), 800, 5, current_img)
    monetka = Monetki((random.randint(0, dis_w - 20), 1, 20, 20), 800, 2, monet_sprite)

    while True:
        clock.tick(60) 
        
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                exit()

            if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
                if klick_pausa.klickkk(event.pos):
                    pauza = not pauza

            if not pauza:
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_UP and on_ground: 
                        y1_change = -12
                        on_ground = False

        if not pauza:
            keys = pygame.key.get_pressed()
            if keys[pygame.K_LEFT]:
                x1_change = -char_coord
            elif keys[pygame.K_RIGHT]:
                x1_change = char_coord
            elif keys[pygame.K_r]:
                return
            else:
                x1_change = 0

            dis.fill(Black)
            
            # --- ФИЗИКА И СТОЛКНОВЕНИЯ ИГРОКА ---
            x1 += x1_change
            if x1 < 0: x1 = 0
            elif x1 > dis_w - player_rect.width: x1 = dis_w - player_rect.width
            player_rect.x = x1

            # Горизонтальные столкновения (стены блоков)
            for fallen in fallen_blocks_X3:
                if player_rect.colliderect(fallen.rect):
                    if x1_change > 0:  
                        player_rect.right = fallen.rect.left
                    elif x1_change < 0:  
                        player_rect.left = fallen.rect.right
                    x1 = player_rect.x

            y1_change += GRAVITY
            y1 += y1_change
            player_rect.y = y1
            
            on_ground = False

            if y1 >= 800 - player_rect.height:
                y1 = 800 - player_rect.height
                y1_change = 0
                on_ground = True
                player_rect.y = y1

            if score >= 100 and not vivod_done:
                vivod_done = True

            if score >= 110 and vivod_done:
                vivod_done = False
        
            elif score >= 200 and not vivod_done2:
                vivod_done2 = True

            elif score >= 210 and vivod_done2:
                vivod_done2 = False
    
            elif score >= 300 and not vivod_done3:
                vivod_done3 = True
    
            elif score >= 310 and not vivod_done4:
                vivod_done4 = True

            if vivod_done:
                dis.blit(text, (10, 20))
                vivod_done = False

            elif vivod_done2:
                dis.blit(text, (10, 20))
                vivod_done2 = False
    
            elif vivod_done3:
                dis.blit(text, (10, 20))
                vivod_done3 = False

            elif vivod_done4:
                dis.blit(text, (10, 20))
                vivod_done4 = False


            timeeviii_upd = pygame.time.get_ticks()
            if timeeviii_upd - timeeviii > 1000:
                score += 1
                timeeviii = timeeviii_upd
                if score > recooord:
                    recooord = score 
            # Вертикальные столкновения (пол и потолок блоков)
            for fallen in fallen_blocks_X3:
                if player_rect.colliderect(fallen.rect):
                    if y1_change > 0:  
                        player_rect.bottom = fallen.rect.top
                        y1_change = 0
                        on_ground = True
                    elif y1_change < 0:  
                        player_rect.top = fallen.rect.bottom
                        y1_change = 0
                    y1 = player_rect.y

            # --- СМЕРТЬ ОТ ПАДАЮЩЕГО БЛОКА ---
            if block.vel > 0 and player_rect.colliderect(block.rect):
                if block.rect.bottom <= player_rect.top + 10: 
                    save_game(recooord)
                    if score > recooord:
                        recooord = score 
                    dis.fill(Black)
                    message("Вы проиграли, сорян >;3", red, dis_w // 6, dis_h // 2)
                    pygame.display.update()
                    time.sleep(2)
                    return 

            if block.move(fallen_blocks_X3):
                fallen_blocks_X3.append(block)
                current_img = random.choice(images)
                block = Level((random.randint(0, dis_w - 100), 0, 100, 30), 800, 4, current_img)

            if len(fallen_blocks_X3) > 35:
                fallen_blocks_X3.pop(0)


            monetka.see(moneta)

            if monetka.rect.bottom >= monetka.y_block: 

                moneta.append(monetka)
                monetka = Monetki((random.randint(0, dis_w-100), 1, 20, 20), 790, 1.5, monet_sprite)

            fal = monetka.see(fallen_blocks_X3)

            if fal:

                moneta.append(monetka)

                monetka = Monetki((random.randint(0, dis_w-100), 1, 20, 20), 790, 1.5, monet_sprite)
            
            
            monetka.drawww(dis)

            if len(moneta) > 7:
                moneta.pop(0)


            for m in moneta[:]:
                monetka.see(moneta)

                current_player_rect = playerXDDDDD.get_rect(topleft=(x1, y1))
                if current_player_rect.colliderect(m.rect):
                    if monetka.rect.bottom <= player_rect.centery + 10:
                        moneta_take.play()
                        score += 5
                        moneta.remove(m)


            # Отрисовка сцены
            dis.blit(playerXDDDDD, player_rect)
            block.draw(dis)
            for fallen in fallen_blocks_X3:
                fallen.draw(dis)
            monetka.drawww(dis)
            klick_pausa.drawX3(dis)
            for m in moneta:
                m.see(moneta) 
                m.drawww(dis)
            monetka.see(moneta)  
            monetka.drawww(dis)
            
            sc_text = font.render(f"Счёт: {score}", True, white)
            dis.blit(sc_text, (10, 10))

            pygame.display.update()

# Главный цикл запуска приложения
while True:
    main_menu()  
    game_loop()  
