class Level():
    def __init__(self, rect, y_floor, vel, img):
        self.rect = pygame.Rect(rect)
        self.y_floor = y_floor
        self.vel = vel
        self.image = pygame.transform.scale(img, (self.rect.width, self.rect.height))

    def move(self, fallen_blocks_X3):
        self.rect.y += self.vel
        if self.rect.bottom >= self.y_floor:
            self.rect.bottom = self.y_floor
            return True 
        for fallen in fallen_blocks_X3:
            if self.rect.colliderect(fallen.rect):
                self.rect.bottom = fallen.rect.top
                return True 
        return False 

    def draw(self, dis):
        dis.blit(self.image, self.rect)

class Monetki():
    def __init__(self, rect, y_block, vel, imagex3):
        self.y_block = y_block
        self.vel = vel
        self.rect = pygame.Rect(rect)
        try:
            self.image2 = pygame.transform.scale(imagex3, (20, 20))
        except:
            self.image2 = pygame.Surface((20, 20))
            self.image2.fill(yellow)
        self.void_play = False

    def see(self, fallen_blocks_X3):
        self.rect.y += self.vel
        if self.rect.bottom >= 800:
            self.rect.bottom = 800
            self.vel = 0
            if not self.void_play and moneta_void: 
                moneta_void.play()     
                self.void_play = True
            return True
        for fallen in fallen_blocks_X3:
            if self.rect.colliderect(fallen.rect):
                if self.vel > 0: 
                    self.rect.bottom = fallen.rect.top
                    self.vel = 0 
                    if not self.void_play and moneta_void: 
                        moneta_void.play()     
                        self.void_play = True
                    return True 
        return False

    def drawww(self, dis):
        dis.blit(self.image2, self.rect)

class Pause():
    def __init__(self, rect, image):
        self.rect = pygame.Rect(rect)
        try:
            self.image = pygame.transform.scale(image, (50, 50))
        except:
            self.image = pygame.Surface((50, 50))
            self.image.fill(white)

    def drawX3(self, dis):
        dis.blit(self.image, self.rect)

    def klickkk(self, mouse_pos):
        return self.rect.collidepoint(mouse_pos)

